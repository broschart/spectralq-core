{% extends "base.html" %}

{% block title %}Watch Zones – VeriTrend{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
<script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
<script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
<style>
  .wz-label-icon { overflow: visible !important; }
  @keyframes wz-pulse {
    0%   { stroke-opacity: 1; r: 18; }
    100% { stroke-opacity: 0; r: 35; }
  }
  @keyframes wz-nearest-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  .wz-nearest-blink { animation: wz-nearest-blink 0.75s step-end infinite; }
  .wz-pulse-ring {
    animation: wz-pulse 1s ease-out infinite;
  }
  .events-subnav {
    display: flex; gap: 0;
    border-bottom: 2px solid var(--border); margin-bottom: 28px;
  }
  .events-subnav a {
    padding: 10px 32px; font-size: 14px; font-weight: 600;
    color: var(--muted); text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px; white-space: nowrap;
    transition: color .12s, border-color .12s;
  }
  .events-subnav a:hover { color: var(--text); }
  .events-subnav a.active { color: var(--text); border-bottom-color: var(--accent1); }

  /* Layout: linke Sidebar + rechts Inhalt */
  .wz-layout {
    display: flex;
    gap: 0;
    min-height: calc(100vh - 220px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .wz-sidebar {
    width: 220px;
    min-width: 220px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .wz-sidebar-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 1px solid var(--border);
    transition: background .12s, color .12s;
    user-select: none;
  }
  .wz-sidebar-item:hover {
    background: var(--surface2);
    color: var(--text);
  }
  .wz-sidebar-item.active {
    background: rgba(124,92,191,.12);
    color: var(--accent1);
    border-left: 3px solid var(--accent1);
    padding-left: 15px;
  }
  .wz-sidebar-item svg {
    flex-shrink: 0;
    opacity: .7;
  }
  .wz-sidebar-item.active svg {
    opacity: 1;
  }
  .wz-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }
  .wz-main-header {
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .wz-panel-desc {
    width: 100%;
    margin: 2px 0 0;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
    order: 10;
  }
  .wz-main-header h2 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }
  .wz-main-body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Karte */
  #wz-map {
    flex: 1;
    min-height: 400px;
  }

  /* Zonen-Liste unter Karte */
  .wz-zone-list {
    padding: 14px 20px;
    border-top: 1px solid var(--border);
    max-height: 240px;
    overflow-y: auto;
  }
  .wz-zone-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 6px;
    margin-bottom: 4px;
    font-size: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .wz-zone-row .wz-zone-name {
    flex: 1;
    font-weight: 500;
    color: var(--text);
  }
  .wz-zone-row .wz-zone-meta {
    color: var(--muted);
    font-size: 11px;
  }
  .wz-zone-row .wz-zone-actions {
    display: flex;
    gap: 6px;
  }
  .wz-zone-row .wz-zone-actions button {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 2px 4px;
    font-size: 12px;
    border-radius: 4px;
    transition: color .12s, background .12s;
  }
  .wz-zone-row .wz-zone-actions button:hover {
    color: var(--text);
    background: var(--surface2);
  }
  .wz-zone-row .wz-zone-actions button.delete:hover {
    color: var(--danger);
  }

  /* Wetter-Panel */
  .wz-weather-panel {
    padding: 20px;
    display: none;
    flex-direction: column;
    gap: 16px;
  }
  .wz-weather-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
  }
  .wz-weather-card h3 {
    margin: 0 0 8px;
    font-size: 14px;
    font-weight: 600;
  }
  .wz-weather-card p {
    margin: 0;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
  }

  .wz-hint {
    color: var(--muted);
    font-size: 12px;
    padding: 20px;
    line-height: 1.6;
  }

  /* Inline edit */
  .wz-inline-edit {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-size: 12px;
    padding: 2px 6px;
    width: 160px;
  }

  /* Resize handles */
  .wz-resize-handle {
    height: 8px;
    flex-shrink: 0;
    cursor: ns-resize;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    user-select: none;
    transition: background .1s;
  }
  .wz-resize-handle:hover,
  .wz-resize-handle.active {
    background: rgba(124,58,237,.12);
  }
  .wz-resize-dots {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    line-height: 1;
    pointer-events: none;
  }
</style>
{% endblock %}

{% block content %}
<div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;flex-wrap:wrap;">
  <h1 style="margin:0;" data-i18n="nav_events">Ereignisse</h1>
  <div style="margin-left:auto;display:flex;align-items:center;gap:8px;">
    <span style="font-size:11px;color:var(--muted);white-space:nowrap;" data-i18n="wz_lbl_project">Projekt:</span>
    <select id="hdr-wz-project"
            style="padding:4px 8px;border-radius:6px;border:1px solid var(--border);
                   background:var(--bg);color:var(--text);font-size:12px;max-width:220px;">
      {% if current_user.is_superadmin %}<option value="" data-i18n="wz_all_projects">– Alle –</option>{% endif %}
    </select>
  </div>
</div>

<div class="events-subnav">
  <a href="/events" data-i18n="ef_nav_manage">Verwalten</a>
  <a href="/events/find" data-i18n="ef_nav_find">Meldungen finden</a>
  <a href="/events/watchzones" class="active" data-i18n="ef_nav_watchzones">Watch Zones</a>
</div>

<div class="wz-layout">
  <!-- Linke Navigation -->
  <div class="wz-sidebar">
    <div class="wz-sidebar-item active" data-panel="global" onclick="wzSelectPanel('global')">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      <span data-i18n="wz_sidebar_global">Global Zones</span>
    </div>
    <div style="border-bottom:2px solid var(--border);"></div>
    {% for p in wz_plugins %}
    <div class="wz-sidebar-item" data-panel="{{ p.plugin_id }}" onclick="wzSelectPanel('{{ p.plugin_id }}')">
      {{ p.meta.icon_svg | safe }}
      <span data-i18n="wz_sidebar_{{ p.plugin_id }}">{{ p.meta.label }}</span>
    </div>
    {% endfor %}
  </div>

  <!-- Hauptbereich -->
  <div class="wz-main">
    <!-- ── Globale Zonen ───────────────────────────────────── -->
    <div id="panel-global" class="wz-panel">
      <div class="wz-main-header">
        <h2 data-i18n="wz_global_title">Global Zones</h2>
        <span style="font-size:11px;color:var(--muted);" data-i18n="wz_global_subtitle">Cross-category zones for all observation types</span>
        <button class="btn btn-primary btn-sm" style="margin-left:auto;" onclick="wzStartDraw('global')" data-i18n="wz_draw_new_zone">
          + Draw New Zone
        </button>
        <p class="wz-panel-desc" data-i18n="wz_global_desc">Global zones apply simultaneously to all observation categories. Once drawn, the zone automatically appears for vessels, aircraft, satellite, etc. – ideal for a permanent observation area you don't want to define multiple times.</p>
      </div>
      <div class="wz-main-body">
        <div id="wz-map-global" class="wz-map-container" style="height:500px;"></div>
        <div class="wz-hint" id="wz-hint-global" data-i18n="wz_global_hint">
          Define cross-category observation zones here that you can reuse across all other categories
          (vessels, aircraft, satellite, etc.) – without having to redraw the zone each time.
        </div>
        <div class="wz-zone-list" id="wz-zones-global"></div>
      </div>
    </div>

    {# ── Plugin-Panels (aus Plugin-Templates) ──────────────── #}
    {% for p in wz_plugins %}
    {% include p.meta.panel_template %}
    {% endfor %}

  </div>
</div>

<!-- Censys-Hinzufügen-Modal -->
<div id="wz-censys-modal" style="display:none;position:fixed;inset:0;z-index:10100;background:rgba(0,0,0,.6);align-items:center;justify-content:center;">
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px;width:480px;max-width:94vw;">
    <h3 style="margin:0 0 18px;font-size:15px;font-weight:600;" data-i18n="wz_censys_modal_title">Create Censys Search</h3>
    <label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;" data-i18n="wz_censys_lbl_name">Name</label>
    <input id="cns-name" type="text" placeholder="e.g. Open SSH Ports DE" style="width:100%;box-sizing:border-box;padding:8px 10px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;margin-bottom:14px;">
    <label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;" data-i18n="wz_censys_lbl_country">Country (ISO code, e.g. DE, UA, RU)</label>
    <input id="cns-country" type="text" maxlength="2" placeholder="DE" style="width:100%;box-sizing:border-box;padding:8px 10px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;margin-bottom:14px;" oninput="_wzCnsPreview()">
    <label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;" data-i18n="wz_censys_lbl_city">City (optional)</label>
    <input id="cns-city" type="text" placeholder="Hamburg" style="width:100%;box-sizing:border-box;padding:8px 10px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;margin-bottom:14px;" oninput="_wzCnsPreview()">
    <label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;" data-i18n="wz_censys_lbl_ports">Ports (comma-separated, optional)</label>
    <input id="cns-ports" type="text" placeholder="22, 80, 443" style="width:100%;box-sizing:border-box;padding:8px 10px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;margin-bottom:14px;" oninput="_wzCnsPreview()">
    <label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;" data-i18n="wz_censys_lbl_service">Service filter (optional, e.g. SSH, HTTP, RDP)</label>
    <input id="cns-service" type="text" placeholder="SSH" style="width:100%;box-sizing:border-box;padding:8px 10px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;margin-bottom:6px;" oninput="_wzCnsPreview()">
    <p id="cns-query-preview" style="font-size:11px;color:var(--muted);font-family:monospace;margin:0 0 18px;min-height:16px;word-break:break-all;"></p>
    <div style="display:flex;gap:10px;justify-content:flex-end;">
      <button onclick="document.getElementById('wz-censys-modal').style.display='none'"
              style="background:none;border:1px solid var(--border);color:var(--muted);border-radius:6px;padding:7px 18px;cursor:pointer;" data-i18n="wz_censys_cancel">Cancel</button>
      <button onclick="_wzCensysSave()"
              style="background:var(--accent1);color:#fff;border:none;border-radius:6px;padding:7px 18px;font-weight:600;cursor:pointer;" data-i18n="wz_censys_save">Save</button>
    </div>
  </div>
</div>

<!-- Lade-Spinner Overlay -->
<div id="wz-loading-overlay" style="display:none;position:fixed;inset:0;z-index:10001;background:rgba(0,0,0,.7);
     align-items:center;justify-content:center;flex-direction:column;gap:16px;">
  <div style="width:48px;height:48px;border:4px solid rgba(255,255,255,.15);border-top-color:#0ea5e9;
              border-radius:50%;animation:wz-spin 0.8s linear infinite;"></div>
  <div id="wz-loading-text" style="color:#fff;font-size:14px;font-weight:500;" data-i18n="wz_sat_loading">Loading satellite image …</div>
</div>
<style>@keyframes wz-spin { to { transform: rotate(360deg); } }</style>

<!-- Traceroute Historische Analyse Modal -->
<div id="wz-hist-modal" style="display:none;position:fixed;inset:0;z-index:10002;background:rgba(0,0,0,.78);
     align-items:center;justify-content:center;" onclick="if(event.target===this)wzCloseHistModal()">
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;
              width:94%;max-width:1200px;max-height:90vh;display:flex;flex-direction:column;
              overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,.5);">
    <div style="padding:12px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;flex-shrink:0;">
      <h3 style="margin:0;font-size:15px;font-weight:600;">&#x1F4CA; Historische Analyse – Traceroute</h3>
      <span id="wz-hist-count" style="font-size:11px;color:var(--muted);"></span>
      <button onclick="(function(){const w=document.getElementById('wz-parcoords-wrap');if(w&&w._pcS){w._pcS.brushes={};w._pcS.axes=null;}wzOpenHistModal();})()"
              style="display:inline-flex;align-items:center;gap:4px;background:transparent;border:1px solid var(--border);
              border-radius:6px;color:var(--muted);padding:4px 10px;cursor:pointer;font-size:11px;margin-left:8px;">
        &#x21BA; Achsen &amp; Filter zurücksetzen
      </button>
      <button onclick="wzCloseHistModal()" style="margin-left:auto;background:transparent;border:1px solid var(--border);
              border-radius:6px;color:var(--muted);padding:4px 10px;cursor:pointer;font-size:13px;">✕</button>
    </div>
    <div style="padding:16px 20px;flex:1;overflow:auto;">
      <div style="font-size:11px;color:var(--muted);margin-bottom:12px;">
        Jede Linie = ein Traceroute-Durchlauf. Grau = ältere Läufe, Lila = neueste. Hover für Details.
      </div>
      <div id="wz-parcoords-wrap" style="width:100%;overflow-x:auto;"></div>
    </div>
  </div>
  <div id="wz-hist-tooltip" style="display:none;position:fixed;background:var(--surface2);border:1px solid var(--border);
       border-radius:8px;padding:10px 14px;font-size:11px;pointer-events:none;z-index:10020;max-width:260px;line-height:1.7;
       box-shadow:0 4px 16px rgba(0,0,0,.4);"></div>
</div>

<!-- Live-Daten Popup -->
<div id="wz-live-overlay" style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.6);
     align-items:flex-start;justify-content:center;overflow-y:auto;padding:2vh 0;" onclick="if(event.target===this)wzCloseLive()">
  <div id="wz-live-spinner" style="display:none;flex-direction:column;align-items:center;gap:16px;">
    <div style="width:44px;height:44px;border:4px solid rgba(255,255,255,.15);border-top-color:#06b6d4;border-radius:50%;animation:wz-spin 0.75s linear infinite;"></div>
    <div id="wz-live-spinner-text" style="font-size:13px;color:rgba(255,255,255,.7);font-family:sans-serif;" data-i18n="wz_spinner_loading">Lade Daten …</div>
  </div>
  <div id="wz-live-box" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;
              width:96%;max-width:1400px;max-height:95vh;display:flex;flex-direction:column;
              overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,.4);transition:max-width .2s;">
    <div style="padding:10px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;flex-shrink:0;">
      <h3 id="wz-live-title" style="margin:0;font-size:15px;font-weight:600;" data-i18n="wz_live_title_default">Live Data</h3>
      <span id="wz-live-count" style="font-size:11px;color:var(--muted);"></span>
      <span style="flex:1;"></span>
      <button id="wz-projection-btn" onclick="wzToggleProjection()" style="display:none;background:var(--accent1);color:#fff;border:none;border-radius:6px;
        padding:4px 12px;font-size:11px;font-weight:600;cursor:pointer;align-items:center;line-height:1;" data-i18n="wz_btn_projection_on">🕐 Hourly Projection</button>
      <button id="wz-heatmap-btn" onclick="wzToggleHeatmap()" style="display:none;background:#0891b2;color:#fff;border:none;border-radius:6px;
        padding:4px 12px;font-size:11px;font-weight:600;cursor:pointer;align-items:center;line-height:1;" data-i18n="wz_btn_heatmap_on">🌡 Density Map</button>

      <button style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:18px;padding:4px;"
              onclick="wzCloseLive()">&#10005;</button>
    </div>
    <!-- Refresh-Leiste (nur Flugzeuge / Schiffe) -->
    <div id="wz-refresh-bar" style="display:none;padding:5px 16px;border-bottom:1px solid var(--border);
         background:var(--surface);flex-shrink:0;display:none;align-items:center;gap:10px;justify-content:flex-end;">
      <span id="wz-refresh-ts" style="font-size:11px;color:var(--muted);"></span>
      <button id="wz-refresh-btn" onclick="wzRefreshLive()"
        style="background:transparent;border:1px solid var(--border);border-radius:6px;
               color:var(--text);padding:3px 12px;font-size:11px;font-weight:600;cursor:pointer;
               display:inline-flex;align-items:center;gap:6px;">
        <span data-i18n="wz_btn_refresh">&#x21bb; Refresh</span>
      </button>
    </div>
    <!-- Karte + Trace-Panel -->
    <div id="wz-map-row" style="display:flex;flex-shrink:0;">
      <div id="wz-live-map" style="height:clamp(200px,42vh,560px);min-height:120px;flex:1;overflow:hidden;position:relative;">
        <div id="wz-cesium-container" style="display:none;position:absolute;inset:0;z-index:500;"></div>
        <div id="wz-hop-hud" style="display:none;position:absolute;bottom:0;left:0;right:0;z-index:1000;
             background:linear-gradient(to top,rgba(0,0,0,.88) 0%,rgba(0,0,0,.7) 70%,transparent 100%);
             padding:18px 20px 14px;pointer-events:none;backdrop-filter:blur(2px);transition:opacity .2s;">
        </div>
      </div>
      <div id="wz-proximity-panel" style="display:none;width:260px;flex-shrink:0;border-left:1px solid var(--border);background:var(--surface);flex-direction:column;overflow:hidden;">
        <div style="padding:8px 12px;border-bottom:1px solid var(--border);font-size:11px;font-weight:700;color:#ef4444;flex-shrink:0;display:flex;align-items:center;gap:6px;">
          <span>⚠</span><span id="wz-prox-title" data-i18n="wz_critical_proximity">Critical Proximity</span>
        </div>
        <div id="wz-prox-list" style="overflow-y:auto;flex:1;font-size:11px;"></div>
      </div>
      <!-- Stundenprojektion Panel -->
      <div id="wz-projection-panel" style="display:none;width:280px;flex-shrink:0;border-left:1px solid var(--border);background:var(--surface);flex-direction:column;overflow:hidden;">
        <div style="padding:8px 12px;border-bottom:1px solid var(--border);font-size:11px;font-weight:700;color:#a78bfa;flex-shrink:0;display:flex;align-items:center;gap:6px;">
          <span>🕐</span><span data-i18n="wz_hour_projection">Hour Projection</span>
        </div>
        <div style="padding:10px 12px;border-bottom:1px solid var(--border);flex-shrink:0;">
          <button id="wz-proj-play-btn" onclick="wzProjPlay()"
            style="width:100%;background:var(--accent1);color:#fff;border:none;border-radius:6px;
                   padding:7px 12px;font-size:12px;font-weight:600;cursor:pointer;
                   display:flex;align-items:center;justify-content:center;gap:6px;">
            <span id="wz-proj-play-icon">▶</span>
            <span id="wz-proj-play-label" data-i18n="wz_start_simulation">Start Simulation</span>
          </button>
          <div id="wz-proj-progress-wrap" style="display:none;margin-top:8px;">
            <div style="background:var(--border);border-radius:3px;height:4px;overflow:hidden;">
              <div id="wz-proj-progress-bar" style="width:0%;height:100%;background:linear-gradient(90deg,#a78bfa,var(--accent1));border-radius:3px;"></div>
            </div>
            <div id="wz-proj-time-label" style="font-size:10px;color:var(--muted);margin-top:4px;text-align:center;">0:00 / 60:00</div>
          </div>
        </div>
        <div id="wz-proj-result-header" style="display:none;padding:6px 12px;border-bottom:1px solid var(--border);font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;flex-shrink:0;"></div>
        <div id="wz-proj-collision-list" style="overflow-y:auto;flex:1;font-size:11px;"></div>
      </div>
      <div id="wz-trace-panel" style="display:none;width:310px;flex-shrink:0;border-left:1px solid var(--border);background:var(--surface);flex-direction:column;overflow:hidden;">
        <div id="wz-trace-header" style="padding:8px 12px;border-bottom:1px solid var(--border);font-size:11px;font-weight:600;color:var(--muted);flex-shrink:0;"></div>
        <div id="wz-trace-list" style="overflow-y:auto;flex:1;font-family:monospace;font-size:11px;"></div>
        <div id="wz-trace-summary" style="display:none;flex-shrink:0;border-top:1px solid var(--border);font-family:monospace;font-size:11px;"></div>
      </div>
    </div>
    <!-- Button-Leiste unter der Karte -->
    <div id="wz-under-map-bar" style="display:none;padding:6px 14px;border-top:1px solid var(--border);background:var(--surface);flex-shrink:0;display:flex;justify-content:flex-end;align-items:center;gap:8px;">
      <button id="wz-hist-btn" onclick="wzOpenHistModal()"
        style="display:none;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--muted);
               padding:5px 14px;font-size:12px;font-weight:600;cursor:pointer;align-items:center;gap:6px;">
        <span data-i18n="wz_btn_historical">&#x1F4CA; Historical Analysis</span>
      </button>
      <button id="wz-traceroute-btn" onclick="wzStartTraceroute()"
        style="background:var(--accent1);border:1px solid var(--accent1);border-radius:6px;color:#fff;
               padding:5px 14px;font-size:12px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;">
        <span data-i18n="wz_btn_traceroute">&#x25B6; Traceroute</span>
      </button>
    </div>
    <div id="wz-resize-map" style="display:none;"></div>
    <!-- Inline Parallel Coordinates -->
    <div id="wz-parcoords-inline" style="display:none;height:320px;min-height:80px;flex-shrink:0;overflow:hidden;
         background:var(--surface);position:relative;">
      <div style="padding:8px 16px 4px;display:flex;align-items:center;gap:8px;">
        <span style="font-size:12px;font-weight:700;color:var(--accent1);" data-i18n="wz_parcoords_title">⫼ Multidimensional Analysis and Filtering</span>
        <span id="wz-parcoords-filter-count" style="font-size:11px;color:var(--muted);"></span>
        <span style="flex:1;"></span>
        <button id="wz-parcoords-reset-btn" onclick="wzResetParCoordsBrushes()" style="display:none;background:none;border:1px solid var(--border);
          color:var(--muted);border-radius:4px;padding:2px 8px;font-size:10px;cursor:pointer;" data-i18n="wz_btn_reset_filter">Reset Filter</button>
        <button onclick="wzToggleParCoords()" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:16px;padding:2px 6px;">&#10005;</button>
      </div>
      <div id="wz-parcoords-body" style="padding:0 16px 8px;position:relative;height:calc(100% - 40px);overflow:hidden;">
        <canvas id="wz-parcoords-canvas"></canvas>
        <div id="wz-parcoords-tooltip" style="display:none;position:absolute;z-index:10;background:var(--surface);
          border:1px solid var(--border);border-radius:6px;padding:6px 10px;font-size:11px;
          box-shadow:0 4px 12px rgba(0,0,0,.3);pointer-events:none;white-space:nowrap;"></div>
      </div>
    </div>
    <!-- Resize-Handle: ParCoords ↔ Liste (nur sichtbar wenn ParCoords offen) -->
    <div class="wz-resize-handle" id="wz-resize-parcoords" data-resize="parcoords" title="Adjust height" style="display:none;">
      <span class="wz-resize-dots">⋯</span>
    </div>
    <!-- Sticky-Header (Button + Tabellenkopf, außerhalb des Scrollbereichs) -->
    <div id="wz-live-sticky" style="display:none;flex-shrink:0;background:var(--surface);border-bottom:1px solid var(--border);"></div>
    <!-- Liste -->
    <div id="wz-live-body" style="flex:1;overflow-y:auto;padding:0;min-height:0;">
      <div id="wz-live-loading" style="text-align:center;padding:30px;color:var(--muted);" data-i18n="wz_loading_live">Loading live data …</div>
      <div id="wz-live-error" style="display:none;text-align:center;padding:20px;color:var(--danger);"></div>
      <div id="wz-live-content" style="display:none;padding:0 16px 12px;"></div>
    </div>
  </div>
</div>

{% endblock %}

{% block scripts %}
<script>
(function(){
  "use strict";

  // ── Watchzone-spezifische Übersetzungen ────────────────────────────────
  window._mergeI18n({
    de: {
      ef_nav_manage: 'Verwalten', ef_nav_find: 'Meldungen finden', ef_nav_watchzones: 'Watch Zones',
      wz_lbl_project: 'Projekt:', wz_all_projects: '– Alle –',
      wz_draw_new_zone: '+ Neue Zone zeichnen',
      wz_active: 'aktiv', wz_inactive: 'inaktiv',
      wz_fetch_live: 'Live-Daten abrufen', wz_fetch_image: 'Satellitenbild abrufen',
      wz_btn_live: 'Live', wz_btn_image: 'Bild', wz_btn_history: 'Verlauf (30 Tage)',
      wz_btn_server: 'Server (Live)', wz_tt_server: 'Server analysieren (Traceroute)',
      wz_tt_toggle: 'Aktiv/Inaktiv', wz_tt_center: 'Auf Karte zentrieren', wz_tt_delete: 'Löschen',
      wz_zone_name_prompt: 'Name der Beobachtungszone:', wz_zone_name_default: 'Neue Zone',
      wz_unknown: 'Unbekannt', wz_show_details_arrow: 'Details anzeigen \u2192', wz_show_details: 'Details anzeigen',
      wz_sidebar_global: 'Globale Zonen', wz_sidebar_vessel: 'Schiffe', wz_sidebar_aircraft: 'Flugzeuge', wz_sidebar_satellite: 'Satellit',
      wz_sidebar_ndvi: 'NDVI / Vegetation', wz_sidebar_weather: 'Wetter / Pegel', wz_sidebar_seismic: 'Seismik',
      wz_sidebar_nightlights: 'Nachtlichter', wz_sidebar_website: 'Webseiten', wz_sidebar_censys: 'Censys',
      wz_global_title: 'Globale Zonen', wz_global_subtitle: 'Kategorien\u00fcbergreifende Zonen f\u00fcr alle Beobachtungstypen',
      wz_global_desc: 'Globale Zonen gelten gleichzeitig f\u00fcr alle Beobachtungskategorien. Einmal gezeichnet, erscheint die Zone automatisch f\u00fcr Schiffe, Flugzeuge, Satellit usw. \u2013 ideal f\u00fcr ein dauerhaftes Beobachtungsgebiet, das nicht mehrfach definiert werden soll.',
      wz_global_hint: 'Hier kategorien\u00fcbergreifende Beobachtungszonen definieren, die in allen anderen Kategorien (Schiffe, Flugzeuge, Satellit usw.) wiederverwendet werden k\u00f6nnen \u2013 ohne die Zone jedes Mal neu zeichnen zu m\u00fcssen.',
      wz_vessel_title: 'Schiffsverfolgung', wz_vessel_source: 'Quelle: VesselFinder / AISHub',
      wz_vessel_desc: '\u00dcberwacht Schiffsbewegungen (AIS) in einem selbst eingezeichneten Seegebiet. Zone auf der Karte einzeichnen, dann auf \u201eLive\u201c klicken \u2013 die Ansicht zeigt alle Schiffe im Bereich mit Name, Kurs und Geschwindigkeit in Echtzeit.',
      wz_vessel_hint: 'Rechtecke oder Polygone auf der Karte einzeichnen, um Seegebiete zu definieren. VesselFinder-Daten zeigen Schiffsbewegungen in Echtzeit.',
      wz_vessel_empty: 'Keine Schiffe in dieser Zone gefunden.',
      wz_vessel_analyse: '\u29fc Schiffsverkehr analysieren', wz_vessel_ships: 'Schiffe', wz_vessel_anomalous: 'auff\u00e4llig',
      wz_vessel_th_type: 'Typ', wz_vessel_th_flag: 'Flagge', wz_vessel_th_speed: 'Geschw.',
      wz_vessel_th_course: 'Kurs', wz_vessel_th_dest: 'Ziel', wz_vessel_th_anomalies: 'Auff\u00e4lligkeiten',
      wz_vessel_no_flag: 'keine Flagge', wz_vessel_usage_label: 'Nutzung', wz_vessel_type_label: 'Schiffstyp',
      wz_vessel_flag_label: 'Flagge', wz_vessel_speed_label: 'Geschw.', wz_vessel_course_label: 'Kurs',
      wz_vessel_dest_label: 'Zielhafen', wz_vessel_localtime_label: 'Ortszeit',
      wz_clock_suffix: '\u00a0Uhr', wz_fetch_time_suffix: ' (Abrufzeit)',
      wz_aircraft_title: 'Flugzeugverfolgung', wz_aircraft_source: 'Quelle: ADS-B Exchange / airplanes.live',
      wz_aircraft_desc: 'Verfolgt Flugzeuge via ADS-B in einem definierten Luftraum. \u201eLive\u201c \u00f6ffnet die Echtzeit-Karte mit H\u00f6he, Kurs und Geschwindigkeit \u2013 kritische N\u00e4he zwischen Maschinen wird farblich hervorgehoben. Klick auf ein Paar zoomt die Karte direkt dorthin.',
      wz_aircraft_hint: 'Luftraum-Zonen auf der Karte einzeichnen. ADS-B-Daten (airplanes.live) zeigen Flugbewegungen in Echtzeit und erm\u00f6glichen Anomalie-Erkennung.',
      wz_aircraft_empty: 'Keine Flugzeuge in dieser Zone gefunden.',
      wz_aircraft_analyse: '\u29fc Flugverkehr analysieren', wz_aircraft_count_zone: 'Flugzeuge in Zone',
      wz_aircraft_th_usage: 'Nutzung', wz_aircraft_th_callsign: 'Rufzeichen', wz_aircraft_th_country: 'Land',
      wz_aircraft_th_alt: 'H\u00f6he', wz_aircraft_th_speed: 'Geschw.', wz_aircraft_th_hdg: 'Kurs', wz_aircraft_th_anomalies: 'Auff\u00e4lligkeiten',
      wz_aircraft_unknown_type: 'Unbekannter Typ', wz_aircraft_no_reg: 'keine Reg.',
      wz_3d_loading: '\u231b Lade\u2026', wz_cesium_error: 'Cesium.js konnte nicht geladen werden. Bitte Internetverbindung pr\u00fcfen.',
      wz_live_title_default: 'Live-Daten', wz_live_prefix_live: 'Live-Daten:', wz_live_prefix_wayback: 'Wayback:', wz_live_prefix_server: 'Server:', wz_live_prefix_satellite: 'Satellitenbild:',
      wz_spinner_loading: 'Lade Daten \u2026', wz_spinner_wayback: 'Lade Wayback-Daten \u2013 ', wz_loading_live: 'Lade Live-Daten \u2026', wz_load_error_prefix: 'Fehler beim Laden:',
      wz_btn_projection_on: '\u{1F550} Stundenprojektion', wz_btn_projection_off: '\u{1F550} Projektion aus',
      wz_btn_heatmap_on: '\u{1F321} Dichte-Karte', wz_btn_heatmap_off: '\u{1F321} Dichte-Karte aus',
      wz_btn_refresh: '\u21bb Aktualisieren', wz_btn_historical: '\u{1F4CA} Historische Analyse', wz_btn_traceroute: '\u25b6 Traceroute',
      wz_critical_proximity: 'Kritische N\u00e4he', wz_hour_projection: 'Stundenprojektion',
      wz_start_simulation: 'Simulation starten', wz_proj_running: 'L\u00e4uft\u2026', wz_proj_restart: 'Neustart', wz_no_collisions: 'Keine Kollisionen projiziert',
      wz_parcoords_title: '\u29fc Mehrdimensionale Analyse und Filter', wz_btn_reset_filter: 'Filter zur\u00fccksetzen',
      wz_ndvi_title: 'NDVI / Vegetation', wz_ndvi_source: 'Quelle: Copernicus Sentinel-2 NDVI',
      wz_ndvi_desc: 'Misst die Vegetationsdichte per Satellit (NDVI-Index). R\u00fcckgang kann auf Abholzung, D\u00fcrre oder landwirtschaftliche Ver\u00e4nderungen hinweisen. Die Zeitreihe erscheint in der Analyse-Zeitleiste unter \u201eZus\u00e4tzliche Quellen\u201c.',
      wz_ndvi_hint: 'Beobachtungsgebiete auf der Karte einzeichnen, f\u00fcr die NDVI-Vegetationsdaten in der Analyse-Zeitleiste angezeigt werden (unter \u201eZus\u00e4tzliche Quellen\u201c).',
      wz_ndvi_data_points: 'Datenpunkte', wz_ndvi_empty: 'Keine NDVI-Daten verf\u00fcgbar. Copernicus-Zugangsdaten erforderlich.',
      wz_ndvi_trend: 'NDVI-Verlauf (90 Tage)', wz_ndvi_statistics: 'Statistik',
      wz_ndvi_current: 'Aktueller NDVI:', wz_ndvi_max: 'Maximum:', wz_ndvi_min: 'Minimum:', wz_ndvi_avg: 'Mittelwert:', wz_ndvi_count: 'Datenpunkte:',
      wz_ndvi_th_date: 'Datum', wz_ndvi_th_rating: 'Bewertung',
      wz_ndvi_dense: 'Dichte Vegetation', wz_ndvi_moderate: 'M\u00e4\u00dfige Vegetation', wz_ndvi_sparse: 'Gering', wz_ndvi_none: 'Kein Gr\u00fcn',
      wz_satellite_title: 'Satellitenbeobachtung', wz_satellite_source: 'Quelle: Copernicus Sentinel-2 (NDVI / Echtfarbe)',
      wz_satellite_desc: 'Ruft aktuelle Satellitenbilder (Sentinel-2) f\u00fcr das Gebiet ab. \u201eBild\u201c l\u00e4dt das neueste Echtfarbbild und zeigt die Aufnahmezeit an. Gut geeignet, um Ver\u00e4nderungen am Boden visuell zu dokumentieren.',
      wz_satellite_hint: 'Beobachtungsgebiete auf der Karte einzeichnen. Sentinel-2-Aufnahmedaten werden automatisch in der Analyse-Zeitleiste markiert (unter \u201eZus\u00e4tzliche Quellen\u201c).',
      wz_sat_to: 'bis', wz_sat_cropped: '(zugeschnitten)', wz_sat_true_color: 'Sentinel-2 Echtfarbe',
      wz_sat_period: 'Zeitraum:', wz_sat_zone_label: 'Zone:', wz_sat_crop_warning: 'Region auf max. 2\u00b0\u00d72\u00b0 zugeschnitten',
      wz_sat_download: 'Bild herunterladen', wz_sat_fullscreen_btn: 'Vollbild / Zoom',
      wz_sat_no_image: 'Kein Satellitenbild verf\u00fcgbar.', wz_sat_click_fullscreen: 'Klicken f\u00fcr Vollbild',
      wz_sat_loading: 'Lade Satellitenbild \u2026', wz_sat_loading_for: 'Lade Satellitenbild f\u00fcr \u201e',
      wz_sat_map_layer: 'Karten-Layer', wz_sat_map_layer_on: 'Karten-Layer (an)',
      wz_sat_rotate_left: 'Links drehen', wz_sat_rotate_right: 'Rechts drehen', wz_sat_toggle_layer: 'Karten-Layer umschalten',
      wz_sat_zoom_out: 'Herauszoomen', wz_sat_update_zone: 'Watchzone anpassen', wz_sat_save_new: 'Als neue Watchzone speichern',
      wz_sat_draw_hint: 'Auswahl ziehen zum Zoomen \u00b7 ESC zum Schlie\u00dfen',
      wz_censys_title: 'Censys-Suche', wz_censys_source: 'Quelle: Censys Search API v2',
      wz_censys_desc: 'Sucht nach exponierten Hosts und Diensten im Internet \u2013 mit geografischem Filter (Land, Stadt) und Port-Filter. \u201eLive\u201c f\u00fchrt die Abfrage aus und zeigt alle gefundenen Hosts mit offenen Ports, Dienst und ASN. Erfordert ein kostenloses Censys-Konto (censys.io).',
      wz_censys_hint: 'Censys-Suche erstellen, um exponierte Dienste in einem bestimmten Land oder einer Region zu \u00fcberwachen. Beispiel: location.country_code=DE and services.port=22',
      wz_censys_add_btn: '+ Suche hinzuf\u00fcgen', wz_censys_modal_title: 'Censys-Suche erstellen',
      wz_censys_lbl_name: 'Name', wz_censys_lbl_country: 'Land (ISO-Code, z.\u202fB. DE, UA, RU)',
      wz_censys_lbl_city: 'Stadt (optional)', wz_censys_lbl_ports: 'Ports (kommagetrennt, optional)',
      wz_censys_lbl_service: 'Dienstfilter (optional, z.\u202fB. SSH, HTTP, RDP)',
      wz_censys_cancel: 'Abbrechen', wz_censys_save: 'Speichern',
      wz_censys_no_hosts: 'Keine Hosts gefunden f\u00fcr:',
      wz_censys_query_label: 'Abfrage:',
      wz_censys_th_ip: 'IP', wz_censys_th_ports: 'Ports', wz_censys_th_services: 'Dienste',
      wz_censys_th_org: 'Organisation', wz_censys_th_location: 'Ort', wz_censys_th_last_seen: 'Zuletzt gesehen',
      wz_censys_alert_filter: 'Bitte mindestens einen Filter angeben (Land, Stadt, Port oder Dienst).',
      wz_censys_default_name: 'Censys-Suche', wz_censys_err_save: 'Fehler:',
      wz_website_title: 'Website-Monitoring', wz_website_source: 'Quelle: Wayback Machine (Internet Archive)',
      wz_website_desc: 'Verfolgt Inhalts\u00e4nderungen einer Website \u00fcber die Wayback Machine. \u201eLive\u201c zeigt eine chronologische Liste aller gespeicherten Snapshots mit Inhaltsgr\u00f6\u00dfe, Titel\u00e4nderungen und Links zur archivierten Version. \u201eServer\u201c startet eine Traceroute-Analyse.',
      wz_website_hint: 'Websites hinzuf\u00fcgen, deren \u00c4nderungen \u00fcber die Wayback Machine verfolgt werden sollen. \u00c4nderungen werden automatisch in der Analyse-Zeitleiste markiert (unter \u201eAndere Quellen\u201c).',
      wz_website_cat_mil: 'Milit\u00e4r', wz_website_cat_pol: 'Politik', wz_website_cat_news: 'Nachrichten',
      wz_website_cat_dis: 'Katastrophenschutz', wz_website_cat_med: 'Medizin',
      wz_website_add_btn: '+ Website hinzuf\u00fcgen', wz_website_modal_title: '\uD83C\uDF10 Website hinzuf\u00fcgen',
      wz_website_lbl_url: 'Website-URL', wz_website_lbl_name: 'Watchzone-Name',
      wz_website_add: '+ Hinzuf\u00fcgen', wz_website_quick_select: 'Schnellauswahl',
      wz_website_no_entries: 'F\u00fcr diese Kombination sind keine Eintr\u00e4ge hinterlegt.',
      wz_website_url_tooltip: 'URL ins Eingabefeld \u00fcbernehmen', wz_website_open_tooltip: 'In neuem Tab \u00f6ffnen',
      wz_website_err_url: 'Bitte eine URL eingeben.', wz_website_err_invalid_url: 'Ung\u00fcltige URL.',
      wz_website_err_hostname: 'Kein g\u00fcltiger Hostname erkennbar.',
      wz_website_checking: 'Pr\u00fcfe \u2026',
      wz_website_err_resolve: 'Domain konnte nicht aufgel\u00f6st werden.',
      wz_website_err_conn: 'Verbindungsfehler:',
      wz_website_server_location: 'Server-Standort', wz_website_server_city: 'Stadt:', wz_website_server_country: 'Land:',
      wz_website_wb_calendar: 'Wayback-Kalender \u2013 letzte 30 Tage', wz_website_page_size: 'Seitengr\u00f6\u00dfe (KB)',
      wz_wb_day_labels: 'Mo,Di,Mi,Do,Fr,Sa,So',
      wz_wb_legend_less: 'Weniger', wz_wb_legend_more: 'Mehr',
      wz_wb_no_snapshots: 'keine Snapshots', wz_wb_filtered: 'gefiltert',
      wz_wb_reset_filter: '\u2715 Filter zur\u00fccksetzen',
      wz_wb_changes_on: '\u00c4nderungen an', wz_wb_days_in_30: 'Tagen in den letzten 30 Tagen',
      wz_wb_per_day: '\u00c4nderungen pro Tag', wz_wb_by_hour: '\u00c4nderungen nach Stunde',
      wz_wb_snapshots: 'Snapshots', wz_wb_entries: 'Eintr\u00e4ge', wz_wb_show_more_snaps: 'weitere Snapshots anzeigen',
      wz_nightlights_title: 'Nachtlichter', wz_nightlights_source: 'Quelle: NASA VIIRS Day/Night Band (GIBS)',
      wz_nightlights_desc: 'Analysiert n\u00e4chtliche Lichtemissionen aus NASA-Satellitendaten (VIIRS). Ver\u00e4nderungen k\u00f6nnen auf wirtschaftliche Aktivit\u00e4t, Infrastrukturentwicklung oder Konflikte hinweisen. Die Zeitreihe erscheint in der Analyse-Zeitleiste.',
      wz_nightlights_hint: 'Beobachtungsgebiete auf der Karte einzeichnen. VIIRS-Nachtlichtdaten (NASA) zeigen die Lichtintensit\u00e4t und ihre Ver\u00e4nderung \u00fcber Zeit in der Analyse-Zeitleiste.',
      wz_nightlights_intensity: 'Lichtintensit\u00e4t',
      wz_nightlights_brightness: 'Mittlere Helligkeit:', wz_nightlights_note: 'H\u00f6here Werte = mehr k\u00fcnstliches Licht.<br>Ver\u00e4nderungen k\u00f6nnen Urbanisierung, Konflikte oder Stromausf\u00e4lle anzeigen.',
      wz_seismic_title: 'Seismische Aktivit\u00e4t', wz_seismic_source: 'Quelle: USGS Earthquake Catalog',
      wz_seismic_desc: 'Zeichnet Erdbeben (USGS) im definierten Gebiet auf \u2013 mit Magnitude, Tiefe und Zeit. Gut geeignet f\u00fcr Krisenregionen oder Gebiete mit bekannter tektonischer Aktivit\u00e4t.',
      wz_seismic_hint: 'Beobachtungsgebiete auf der Karte einzeichnen. Erdbebenaktivit\u00e4t (USGS) wird automatisch in der Analyse-Zeitleiste angezeigt (unter \u201eAndere Quellen\u201c).',
      wz_seismic_count: 'Erdbeben (30 Tage)',
      wz_seismic_header: 'Erdbeben der letzten 30 Tage',
      wz_seismic_empty: 'Keine Erdbeben in dieser Region verzeichnet.',
      wz_seismic_depth: 'Tiefe:', wz_seismic_more: 'weitere',
      wz_weather_title: 'Wetter &amp; Pegel', wz_weather_source: 'Quelle: DWD / NOAA',
      wz_weather_desc: 'Ruft Wetter- und Pegelstandsdaten (DWD/NOAA) f\u00fcr das gezeichnete Gebiet ab. N\u00fctzlich, um Wetterereignisse mit anderen Beobachtungen zu korrelieren \u2013 z.\u00a0B. St\u00fcrme mit erh\u00f6htem Schiffsverkehr oder Hochwassergefahr.',
      wz_weather_hint: 'Beobachtungsgebiete auf der Karte einzeichnen, f\u00fcr die Wetter- und Pegelstandsdaten abgerufen werden sollen.',
      wz_weather_station: 'Wetterstation',
      wz_weather_current: 'Aktuelle Bedingungen',
      wz_weather_warnings: 'Wetterwarnungen',
      wz_weather_no_warnings: 'Keine aktiven Warnungen.',
      wz_weather_temp: 'Temperatur:', wz_weather_dew: 'Taupunkt:', wz_weather_humidity: 'Luftfeuchtigkeit:',
      wz_weather_wind: 'Wind:', wz_weather_gusts: 'B\u00f6en:', wz_weather_pressure: 'Luftdruck:',
      wz_weather_clouds: 'Bew\u00f6lkung:', wz_weather_visibility: 'Sicht:', wz_weather_precip: 'Niederschlag:',
      wz_weather_condition: 'Wetterlage:', wz_weather_warn_level: 'Level:',
