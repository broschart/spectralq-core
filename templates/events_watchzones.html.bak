      wz_sidebar_ndvi: 'NDVI / V\u00e9g\u00e9tation', wz_sidebar_weather: 'M\u00e9t\u00e9o / Niveau d\u2019eau', wz_sidebar_seismic: 'S\u00e9ismique',
      wz_sidebar_nightlights: 'Lumi\u00e8res nocturnes', wz_sidebar_website: 'Sites web', wz_sidebar_censys: 'Censys',
      wz_global_title: 'Zones globales', wz_global_subtitle: 'Zones transversales pour tous les types d\u2019observation',
      wz_global_desc: 'Les zones globales s\u2019appliquent simultan\u00e9ment \u00e0 toutes les cat\u00e9gories d\u2019observation. Une fois dessin\u00e9e, la zone appara\u00eet automatiquement pour les navires, a\u00e9ronefs, satellite, etc. \u2013 id\u00e9al pour une zone d\u2019observation permanente.',
      wz_global_hint: 'D\u00e9finissez ici des zones d\u2019observation transversales r\u00e9utilisables dans toutes les autres cat\u00e9gories (navires, a\u00e9ronefs, satellite, etc.) \u2013 sans avoir \u00e0 redessiner la zone \u00e0 chaque fois.',
      wz_vessel_title: 'Suivi des navires', wz_vessel_source: 'Source\u00a0: VesselFinder / AISHub',
      wz_vessel_desc: 'Surveille les mouvements de navires (AIS) dans une zone maritime d\u00e9finie. Dessinez une zone sur la carte, puis cliquez sur \u00ab\u00a0Direct\u00a0\u00bb \u2013 la vue affiche tous les navires dans la zone avec nom, cap et vitesse en temps r\u00e9el.',
      wz_vessel_hint: 'Dessinez des rectangles ou des polygones sur la carte pour d\u00e9finir des zones maritimes. Les donn\u00e9es VesselFinder montrent les mouvements de navires en temps r\u00e9el.',
      wz_vessel_empty: 'Aucun navire trouv\u00e9 dans cette zone.',
      wz_vessel_analyse: '\u29fc Analyser le trafic maritime', wz_vessel_ships: 'navires', wz_vessel_anomalous: 'anormaux',
      wz_vessel_th_type: 'Type', wz_vessel_th_flag: 'Pavillon', wz_vessel_th_speed: 'Vitesse',
      wz_vessel_th_course: 'Cap', wz_vessel_th_dest: 'Dest.', wz_vessel_th_anomalies: 'Anomalies',
      wz_vessel_no_flag: 'sans pavillon', wz_vessel_usage_label: 'Usage', wz_vessel_type_label: 'Type de navire',
      wz_vessel_flag_label: 'Pavillon', wz_vessel_speed_label: 'Vitesse', wz_vessel_course_label: 'Cap',
      wz_vessel_dest_label: 'Port de dest.', wz_vessel_localtime_label: 'Heure locale',
      wz_clock_suffix: '', wz_fetch_time_suffix: ' (heure d\u2019appel)',
      wz_aircraft_title: 'Suivi des a\u00e9ronefs', wz_aircraft_source: 'Source\u00a0: ADS-B Exchange / airplanes.live',
      wz_aircraft_desc: 'Suit les a\u00e9ronefs via ADS-B dans un espace a\u00e9rien d\u00e9fini. \u00ab\u00a0Direct\u00a0\u00bb ouvre la carte en temps r\u00e9el avec l\u2019altitude, le cap et la vitesse \u2013 la proximit\u00e9 critique entre appareils est indiqu\u00e9e par des couleurs. Cliquez sur une paire pour zoomer sur la carte.',
      wz_aircraft_hint: 'Dessinez des zones d\u2019espace a\u00e9rien sur la carte. Les donn\u00e9es ADS-B (airplanes.live) affichent les mouvements en temps r\u00e9el et permettent la d\u00e9tection d\u2019anomalies.',
