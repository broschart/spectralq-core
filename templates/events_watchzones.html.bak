      wz_vessel_analyse: '\u29fc Analizar tr\u00e1fico mar\u00edtimo', wz_vessel_ships: 'embarcaciones', wz_vessel_anomalous: 'an\u00f3malas',
      wz_vessel_th_type: 'Tipo', wz_vessel_th_flag: 'Bandera', wz_vessel_th_speed: 'Veloc.',
